# Copy to backend/.env and fill in real values. Never commit the real .env.

# Postgres (Supabase Session Pooler URL)
DATABASE_URL=postgresql://postgres.PROJECT_REF:DB_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# Server-only secret shared with the frontend (random string).
# Rotate this any time. The frontend must use the same value.
INTERNAL_API_KEY=replace_with_random_string

# Google Gemini
GEMINI_API_KEY=

# Stripe (test mode keys)
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional: leave empty unless using Google Sign-In on web
GOOGLE_CLIENT_ID=

# Optional: extra allowed CORS origins (comma-separated)
CORS_ORIGINS=
